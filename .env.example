# Alpha Vantage API Key（必需，用于获取美股/港股/全球指数历史数据）
# 获取地址：https://www.alphavantage.co/support/#api-key
# 免费额度：每天 25 次请求
ALPHA_VANTAGE_API_KEY=your_api_key_here

# 数据库路径（可选，默认使用 backend/database.db）
# DATABASE_PATH=/path/to/database.db

# 代理设置（可选，如果网络需要代理）
# HTTP_PROXY=http://192.168.1.50:7897
# HTTPS_PROXY=http://192.168.1.50:7897

# 日志级别（可选，默认 info）
# LOG_LEVEL=info
