# Alpha Vantage API Key（必需，用于获取美股/港股/全球指数历史数据）
# 获取地址：https://www.alphavantage.co/support/#api-key
# 免费额度：每天 25 次请求
ALPHA_VANTAGE_API_KEY=your_api_key_here

# Admin API Key（用于管理接口认证）
ADMIN_API_KEY=

# 数据库路径（可选，默认使用 backend/database.db）
# DATABASE_PATH=/path/to/database.db

# 代理设置（可选，如果网络需要代理）
HTTP_PROXY=http://192.168.1.50:7897
HTTPS_PROXY=http://192.168.1.50:7897

# 环境设置（development, staging, production）
ENV=development

# 调试模式（生产环境必须为 false）
DEBUG_MODE=false

# 日志级别（可选，默认 info）
# LOG_LEVEL=info

# CORS 允许的源（逗号分隔，默认 * 允许所有）
# ALLOWED_ORIGINS=http://localhost:3000,http://example.com

# 后端服务器配置
# BACKEND_HOST=0.0.0.0
# BACKEND_PORT=8002

# 前端服务器配置
# FRONTEND_HOST=0.0.0.0
# FRONTEND_PORT=60100

# Agent 调试标志（生产环境必须为 false）
AGENT_DB_DEBUG=false
AGENT_AUTH_DEBUG=false

# 前端环境变量（Vite）
# VITE_BACKEND_HOST=127.0.0.1
# VITE_BACKEND_PORT=8002
# VITE_FRONTEND_HOST=0.0.0.0
# VITE_FRONTEND_PORT=60100
# VITE_API_TIMEOUT=8000
# VITE_DEBUG_MODE=false
